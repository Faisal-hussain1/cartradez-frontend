# Used by frontend to call backend APIs
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Frontend base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment flag (frontend only)
NEXT_PUBLIC_ENV="development"

# Sentry (frontend monitoring)
NEXT_PUBLIC_SENTRY_DSN="https://63c12b64..."
SENTRY_PROJECT="cartradez-frontend"
SENTRY_ORG="kabeer-s6"

# AWS bucket host for images
NEXT_PUBLIC_AWS_BUCKET_HOSTNAME="cartradez.s3.amazonaws.com"